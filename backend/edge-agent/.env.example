# /etc/looplance/edge.env
# Gerado automaticamente pelo script /api/public/edge-setup/:id
# (mantenha 600 root:root -- contém edge_token)

# Identidade do device (id da linha em edge_devices)
EDGE_DEVICE_ID=00000000-0000-0000-0000-000000000000
EDGE_TOKEN=changeme

# Mesmo valor de EDGE_SHARED_SECRET configurado no ambiente do servidor
# (app). Usado para assinar (HMAC-SHA256) heartbeat/replay/camera-status/
# config -- defesa extra além do EDGE_TOKEN. NUNCA reaproveite este valor
# como EDGE_TOKEN de nenhum device.
EDGE_SHARED_SECRET=changeme

# Backend (TanStack server routes)
API_BASE_URL=https://looplance.app

# Supabase (usado só pelo heartbeat direto via REST, conforme spec 6.2)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=changeme

# Cloudflare R2 - replays (VOD)
R2_BUCKET_NAME=looplance-replays
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=changeme
R2_SECRET_ACCESS_KEY=changeme
R2_PUBLIC_BASE_URL=https://videos.looplance.app

# Cloudflare R2 - live (HLS)
R2_LIVE_BUCKET_NAME=looplance-live
R2_LIVE_PUBLIC_BASE_URL=https://download.looplance.app

# Buffer RAM (tmpfs)
RAM_BUFFER_DIR=/dev/shm/looplance
SEGMENT_SECONDS=2

# HLS ao vivo
HLS_SEGMENT_SECONDS=2
HLS_LIST_SIZE=6

# Heartbeat
HEARTBEAT_INTERVAL_SECONDS=30
EDGE_VERSION=1.0.0

