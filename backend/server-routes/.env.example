# .env do APP (onde os server-routes /api/public/* rodam — Vercel/Cloudflare/etc)
# Nomes alinhados com o ambiente Lovable Cloud que vocês já usam.
# Só entram aqui variáveis que os server-routes deste pacote realmente leem.

# =========================================
# 1. SUPABASE — já existem, usadas por supabaseAdmin.server.ts
# =========================================
SUPABASE_URL="https://jurwopyuxmhvtwzjxynm.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<secreta — só backend, NUNCA no frontend>"
# SUPABASE_ANON_KEY / SUPABASE_PUBLISHABLE_KEY / SUPABASE_JWKS / SUPABASE_DB_URL
# não são usadas pelos endpoints /api/public/edge/* e /api/public/cron/*
# (eles usam exclusivamente o service role), mas seguem necessárias pro
# resto da aplicação (auth de usuários, admin, etc).

# =========================================
# 2. CLOUDFLARE R2 — já existem, usadas por r2.server.ts (cleanup-replays)
# =========================================
R2_ACCESS_KEY_ID="<access key id do R2>"
R2_SECRET_ACCESS_KEY="<secret access key do R2>"
R2_ENDPOINT_URL="https://<accountid>.r2.cloudflarestorage.com"
R2_BUCKET_NAME="looplance-replays"
# R2_PUBLIC_BASE_URL e R2_ACCOUNT_ID não são usadas pelo servidor (quem monta
# a video_url final é o Edge Agent, no upload) — mas fiquem documentadas
# aqui também pra bater com o .env do edge-agent.
R2_PUBLIC_BASE_URL="https://replays.looplance.app"

# =========================================
# 4. EDGE DEVICES (M2M) — usadas por edgeAuth.server.ts
# =========================================
# Mesmo valor que cada device tem no seu /etc/looplance/edge.env.
# Rotacionar isso exige atualizar TODOS os edges + o servidor ao mesmo tempo.
EDGE_SHARED_SECRET="<32+ chars aleatórios>"
# Protege POST /api/public/cron/cleanup-replays (header x-cron-secret)
CRON_SECRET="<32+ chars aleatórios>"

# =========================================
# 5. APP
# =========================================
# Usada como fallback de retenção em cleanup-replays.ts quando uma arena
# não tem arena_settings.replay_retention_days configurado.
REPLAY_TTL_HOURS="72"
# APP_BASE_URL / PUBLIC_API_BASE_URL não são lidas pelo código deste pacote
# (os server-routes já ficam montados relativamente em /api/public/*), mas
# são a URL que deve ir em API_BASE_URL do .env de cada Edge Device.
NODE_ENV="production"
